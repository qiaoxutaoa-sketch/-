/* pages/records/records.wxss */
.header-section {
  padding: 40rpx 40rpx 20rpx;
}
.title {
  display: block;
  font-size: 56rpx;
  font-weight: 900;
  color: var(--gray-900);
}
.subtitle {
  font-size: 28rpx;
  color: var(--gray-500);
}

.records-list {
  padding-bottom: 60rpx;
}
.record-card {
  display: flex;
  flex-direction: column;
}
.record-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1px dashed var(--gray-200);
}
.rt-left {
  display: flex;
  flex-direction: column;
}
.r-course {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--gray-900);
}
.r-date {
  font-size: 24rpx;
  color: var(--gray-500);
  margin-top: 8rpx;
}
.rt-right {
  background: rgba(239, 68, 68, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}
.r-consume {
  color: var(--danger);
  font-weight: 700;
  font-size: 26rpx;
}

.r-teacher {
  font-size: 26rpx;
  margin-bottom: 24rpx;
}
.r-label {
  color: var(--gray-500);
}
.r-val {
  font-weight: 600;
  color: var(--gray-800);
}

.r-comment-box {
  background: var(--gray-50);
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}
.r-comment-title {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 16rpx;
}
.r-comment-text {
  font-size: 28rpx;
  color: var(--gray-700);
  line-height: 1.6;
}

.r-photos {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}
.r-photo-item {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 16rpx;
  object-fit: cover;
  background-color: var(--gray-200);
}
