page {
  background: #000;
  overflow: hidden;
}

.lab-container {
  width: 100vw;
  height: 100vh;
  position: relative;
}

.webgl-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 1; /* 底层 */
}

.scroll-area {
  position: absolute;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 10; /* 覆盖在 WebGL 之上捕获滚动 */
}

.scroll-content {
  height: 400vh; /* 超长内容触发滚动 */
  pointer-events: none; /* 让所有的点击透过去，虽然没有点击 */
}

.nav-header {
  padding-top: 100rpx;
  padding-left: 40rpx;
  display: flex;
  align-items: center;
}

.back-btn {
  color: #fff;
  font-size: 28rpx;
  background: rgba(255,255,255,0.2);
  padding: 12rpx 30rpx;
  border-radius: 100px;
  margin-right: 30rpx;
}

.title {
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}

/* 模拟底部悬浮的胶囊文字层（纯文本和图标，没有底座，底座由 WebGL 渲染） */
.hud-mock {
  position: absolute;
  bottom: 60rpx;
  left: 50%;
  transform: translateX(-50%);
  height: 100rpx;
  display: flex;
  align-items: center;
  padding: 0 36rpx;
  z-index: 900;
  pointer-events: none;
}

.capsule-logo {
  height: 72rpx;
  width: auto;
  filter: drop-shadow(0 6px 4px rgba(0, 0, 0, 0.3));
}

.capsule-divider {
  width: 1px;
  height: 36rpx;
  background: rgba(255, 255, 255, 0.4);
  margin: 0 24rpx;
}

.capsule-text {
  color: rgba(255,255,255,0.95);
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 0.5px;
  filter: drop-shadow(0 6px 4px rgba(0, 0, 0, 0.3));
}

.capsule-dot {
  width: 12rpx;
  height: 12rpx;
  background: #FF4A4A;
  border-radius: 50%;
  margin-left: 20rpx;
  filter: drop-shadow(0 4px 6px rgba(255, 74, 74, 0.4));
}
