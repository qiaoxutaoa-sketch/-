/* pages/about/about.wxss */

.about-page {
  min-height: 100vh;
  background: #F5F5F7;
  padding: 0 32rpx 80rpx;
}

/* === 品牌展示区 === */
.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 60rpx;
}

.brand-logo {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
}

.brand-name {
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  color: var(--text-primary);
}

.brand-slogan {
  font-size: 24rpx;
  font-weight: 500;
  letter-spacing: 6rpx;
  color: var(--text-muted);
  margin-top: 12rpx;
}

/* === 卡片通用 === */
.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  color: var(--text-primary);
  margin-bottom: 32rpx;
}

/* === 品牌故事 === */
.story-text {
  font-size: 26rpx;
  line-height: 1.9;
  color: var(--text-secondary);
  letter-spacing: 0.5rpx;
}

/* === 联系我们 === */
.contact-row {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
}

.contact-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 28rpx;
  margin-top: 4rpx;
}

/* 地址图标：蓝色 */
.icon-location {
  background: rgba(30, 111, 186, 0.1);
}
.icon-dot {
  width: 16rpx;
  height: 16rpx;
  background: var(--brand-blue);
  border-radius: 50%;
  box-shadow: 0 0 0 6rpx rgba(30, 111, 186, 0.2);
}

/* 电话图标：橙色 */
.icon-phone {
  background: rgba(232, 148, 42, 0.1);
}
.icon-phone-shape {
  width: 22rpx;
  height: 22rpx;
  border: 4rpx solid var(--brand-orange);
  border-radius: 0 8rpx 0 8rpx;
  transform: rotate(-45deg);
}

/* 时间图标：灰色 */
.icon-clock {
  background: rgba(0, 0, 0, 0.06);
}
.icon-clock-shape {
  width: 24rpx;
  height: 24rpx;
  border: 3rpx solid var(--text-muted);
  border-radius: 50%;
  position: relative;
}
.icon-clock-shape::after {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 50%;
  width: 2rpx;
  height: 8rpx;
  background: var(--text-muted);
  transform-origin: bottom center;
  transform: translateX(-50%);
}

.contact-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.contact-label {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.contact-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.5rpx;
}

.contact-action {
  font-size: 22rpx;
  color: var(--brand-blue);
  margin-top: 8rpx;
}

.contact-sub {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 6rpx;
}

.contact-divider {
  height: 1px;
  background: var(--divider);
  margin: 16rpx 0 16rpx 92rpx;
}

/* === 页脚 === */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}

.footer-version {
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 2rpx;
}

.footer-copy {
  font-size: 20rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
  letter-spacing: 1rpx;
}
