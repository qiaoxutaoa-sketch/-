/* pages/bind/bind.wxss */
page {
  background-color: #F8F9FA;
}

.container {
  min-height: 100vh;
  box-sizing: border-box;
}

/* 导航栏液态玻璃材质 */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 999;
  
  /* 液态玻璃 V3 —— 极致通透 */
  background: linear-gradient(
    180deg,
    rgba(248, 249, 250, 0.25) 0%,
    rgba(248, 249, 250, 0.08) 100%
  );
  backdrop-filter: blur(12px) saturate(200%) brightness(1.02);
  -webkit-backdrop-filter: blur(12px) saturate(200%) brightness(1.02);
  
  /* 底部折射线 */
  border-bottom: 0.5px solid rgba(255, 255, 255, 0.25);
  
  /* 轻量光影 */
  box-shadow:
    inset 0 -0.5px 0 rgba(0, 0, 0, 0.02),
    0 1px 8px rgba(0, 0, 0, 0.015);
  
  display: flex;
  align-items: center;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  width: 100%;
  height: 100%;
  box-sizing: border-box;
}

.icon-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 4rpx;
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
}

.dot {
  background-color: #64748b;
  border-radius: 50%;
  width: 8rpx;
  height: 8rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1e293b;
  letter-spacing: 2rpx;
}

.nav-bell {
  font-size: 40rpx;
  /* position adjustment if capsule is there */
  margin-right: 180rpx; 
}

/* 基础卡片样式 */
.content-card {
  background: #ffffff;
  border-radius: 40rpx;
  margin: 0 30rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.02);
}

/* 个人主页卡片 */
.profile-header {
  padding: 50rpx 40rpx;
  display: flex;
  align-items: center;
}

.avatar-wrap {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin-right: 30rpx;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #f1f5f9;
}

.edit-icon {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: #475569;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: white;
  border: 4rpx solid #ffffff;
}

.info-wrap {
  display: flex;
  flex-direction: column;
}

.p-name {
  font-size: 44rpx;
  font-weight: 900;
  color: #0f172a;
  margin-bottom: 8rpx;
}

.p-phone-btn {
  display: inline-flex;
  align-items: center;
  background: transparent;
  color: #94a3b8;
  font-size: 26rpx;
}

.p-icon {
  margin-right: 10rpx;
  font-size: 24rpx;
}

/* 四宫格导航 */
.grid-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30rpx;
  margin: 0 30rpx;
}

.grid-card {
  background: #ffffff;
  border-radius: 30rpx;
  padding: 50rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.02);
}

.g-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
  color: #1e293b;
}

.g-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1e293b;
  margin-bottom: 6rpx;
}

.g-en {
  font-size: 20rpx;
  color: #cbd5e1;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

/* 弹窗遮罩 */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0,0,0,0.4);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.popup-content {
  width: 85%;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  border-radius: 40rpx;
  padding: 40rpx;
  box-shadow: 0 20rpx 40rpx rgba(0,0,0,0.1);
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.p-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #0f172a;
}

.p-close {
  font-size: 44rpx;
  color: #94a3b8;
  padding: 0 20rpx;
  line-height: 1;
}

/* 表单复用样式 */
.form-container {
  display: flex;
  flex-direction: column;
}

.form-group {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: var(--gray-500);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.input, .picker-input {
  height: 88rpx;
  background: #f1f5f9;
  border-radius: 16rpx;
  padding: 0 30rpx;
  font-size: 30rpx;
  color: var(--gray-900);
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
  line-height: 88rpx; /* for picker */
}

.flex-row {
  display: flex;
  justify-content: space-between;
}
.flex-1 {
  flex: 1;
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  background: var(--primary);
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 30rpx rgba(59, 130, 246, 0.3);
  transition: all 0.3s ease;
}
