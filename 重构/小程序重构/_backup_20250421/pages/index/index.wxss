/* pages/index/index.wxss */
page {
  background-color: #F8F9FA;
}

.container {
  min-height: 100vh;
  box-sizing: border-box;
}

/* 导航栏液态玻璃材质 */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 999;
  
  /* 液态玻璃 V3 —— 极致通透 */
  background: linear-gradient(
    180deg,
    rgba(248, 249, 250, 0.25) 0%,
    rgba(248, 249, 250, 0.08) 100%
  );
  backdrop-filter: blur(12px) saturate(200%) brightness(1.02);
  -webkit-backdrop-filter: blur(12px) saturate(200%) brightness(1.02);
  
  /* 底部折射线 */
  border-bottom: 0.5px solid rgba(255, 255, 255, 0.25);
  
  /* 轻量光影 */
  box-shadow:
    inset 0 -0.5px 0 rgba(0, 0, 0, 0.02),
    0 1px 8px rgba(0, 0, 0, 0.015);
  
  display: flex;
  align-items: center;
}

.nav-content {
  display: flex;
  align-items: center;
  padding-left: 30rpx;
  height: 100%;
}

.icon-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 4rpx;
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
}

.dot {
  background-color: #64748b;
  border-radius: 50%;
  width: 8rpx;
  height: 8rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1e293b;
  letter-spacing: 2rpx;
}

/* 基础卡片样式 */
.content-card {
  background: #ffffff;
  border-radius: 40rpx;
  margin: 0 30rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.02);
  position: relative;
  overflow: hidden;
}

/* 学员卡片 */
.student-card {
  padding: 80rpx 40rpx 40rpx; /* 为左上角的 tag 留空间 */
}

.top-tag {
  position: absolute;
  top: 30rpx;
  left: 30rpx;
  background: #475569;
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  font-weight: bold;
}

.profile-row {
  display: flex;
  align-items: center;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #f1f5f9;
  margin-right: 30rpx;
}

.info-col {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.name {
  font-size: 40rpx;
  font-weight: 900;
  color: #0f172a;
  margin-bottom: 6rpx;
}

.course-text {
  font-size: 26rpx;
  color: #64748b;
}

.arrow {
  font-size: 50rpx;
  color: #cbd5e1;
  font-weight: 300;
}

/* 课时看板 */
.stats-row {
  display: flex;
  padding: 10rpx;
  background: transparent;
  box-shadow: none;
  margin-bottom: 20rpx;
}

.stat-box {
  flex: 1;
  border-radius: 40rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.left-box {
  background: #ffffff;
  margin-right: 15rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.02);
}

.right-box {
  background: #f1f5f9;
  margin-left: 15rpx;
  align-items: center;
}

.stat-label {
  font-size: 26rpx;
  color: #64748b;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.stat-value-large {
  font-size: 80rpx;
  font-weight: 900;
  color: #475569;
  line-height: 1;
  margin-top: 10rpx;
}

.stat-value-small {
  font-size: 48rpx;
  font-weight: 900;
  color: #475569;
  line-height: 1;
  margin-top: 10rpx;
}

/* 最新点评 */
.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 40rpx 40rpx 20rpx;
}

.s-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #1e293b;
}

.s-link {
  font-size: 26rpx;
  color: #94a3b8;
}

.review-card {
  padding: 30rpx;
}

.black-placeholder {
  width: 100%;
  height: 500rpx;
  background-color: #1a1a1a;
  border-radius: 30rpx;
}

/* 空状态与动画保留 */
.empty-state {
  padding-top: 100rpx;
}

.btn-primary {
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
}
